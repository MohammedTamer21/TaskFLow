@model List<TaskItem>

@{
    ViewData["Title"] = "My Tasks";
}

<h2>Welcome @Context.Session.GetString("Username")</h2>

<p>
    <a href="/Task/Add">Add New Task</a> |
    <a href="/Account/Profile">My Profile</a> |
    <a href="/Account/Logout">Logout</a>
</p>

<table border="1" cellpadding="5">
    <thead>
        <tr>
            <th>Title</th>
            <th>Description</th>
            <th>Status</th>
            <th>Due Date</th>
            <th>Actions</th>
        </tr>
    </thead>
    <tbody>
        @foreach (var task in Model)
        {
            <tr>
                <td>@task.Title</td>
                <td>@task.Description</td>
                <td>@task.Status</td>
                <td>@task.DueDate.ToShortDateString()</td>
                <td>
                    <a href="/Task/Edit/@task.TaskId">Edit</a> |
                    <a href="/Task/Delete/@task.TaskId">Delete</a>
                </td>
            </tr>
        }
    </tbody>
</table>